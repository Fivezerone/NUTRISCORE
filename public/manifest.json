{
  "manifest_version": 3,
  "name": "NutriScore Checkout Tool",
  "short_name": "NutriScore",
  "version": "0.1.0",
  "description": "See Nutri-Score grades on Jumia grocery products before you buy.",

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "NutriScore"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.jumia.co.ke/*"
      ],
      "js": ["content-script/index.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["assets/widget.css", "assets/*.css"],
      "matches": ["https://www.jumia.co.ke/*"]
    }
  ],

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.jumia.co.ke/*",
    "https://world.openfoodfacts.org/*"
  ]
}
