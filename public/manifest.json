{
  "manifest_version": 3,
  "name": "NutriScore Checkout Tool",
  "version": "0.1.0",
  "description": "Scans Carrefour Kenya grocery pages, fetches nutrition data, and surfaces Nutri-Score insights in a shadow DOM widget.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.carrefour.ke/*",
    "https://*.carrefour.ke/*",
    "https://world.openfoodfacts.org/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.carrefour.ke/*", "https://*.carrefour.ke/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "NutriScore",
    "default_popup": "popup.html"
  },
  "options_page": "dashboard.html"
}